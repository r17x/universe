# How: `*` ignores everything, then `!path` whitelists source files.
# `!*/` allows git to traverse directories. If it's not listed, it's not tracked.
*

!*/

!.gitattributes
!.gitignore
!.sops.yaml
!ARCHITECTURE.md
!BACALAH.md
!CLAUDE.md
!README.md
!flake.nix
!flake.lock

# settings.local.json is NOT whitelisted (machine-specific)
!.claude/agents/**
!.claude/commands/**
!.claude/docs/**
!.claude/hooks/**
!.claude/memories/**
!.claude/settings.json
!.claude/skill-library/**
!.claude/skills/**
!.github/**
!.serena/**
!apps/**
!nix/**
!notes/**
!secrets/**
