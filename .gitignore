# IGNORE EVERYTHING EXCEPT OUR SOURCE
#
# Principle: Start by ignoring all files, then explicitly whitelist only
# what belongs in version control. If it's not listed below, it's not tracked.
#
# How it works:
#   *    — ignore everything by default
#   !*/  — allow git to traverse into directories (required for nested whitelists)
#   !path — whitelist specific files or globs

*
!*/

# ── Root files ──────────────────────────────────────────────────────────────────
!/.gitattributes
!/.gitignore
!/.sops.yaml
!/ARCHITECTURE.md
!/BACALAH.md
!/CLAUDE.md
!/README.md
!/flake.nix
!/flake.lock

# ── .claude/ ────────────────────────────────────────────────────────────────────
# NOTE: .claude/settings.local.json is NOT whitelisted (machine-specific)
!.claude/agents/**
!.claude/commands/**
!.claude/docs/**
!.claude/hooks/**
!.claude/memories/**
!.claude/settings.json
!.claude/skill-library/**
!.claude/skills/**

# ── .github/ ────────────────────────────────────────────────────────────────────
!.github/**

# ── .serena/ ────────────────────────────────────────────────────────────────────
!.serena/**

# ── apps/ ───────────────────────────────────────────────────────────────────────
# Source-only allow-list for all projects under apps/
# JS/TS ecosystem
!apps/*/package.json
!apps/*/bun.lock
!apps/*/tsconfig.json
!apps/*/yarn.lock
!apps/*/.yarnrc.yml
!apps/*/vite.config.mjs
!apps/*/tamagui.config.ts
# OCaml/Reason ecosystem
!apps/*/dune
!apps/*/dune-project
!apps/*/*.opam
!apps/*/.ocamlformat
# Source and content
!apps/*/src/**
!apps/*/bin/**
!apps/*/client/**
!apps/*/server/**
!apps/*/universal/**
!apps/*/*.html
!nix/**
!notes/**
!secrets/**

# ── Explicitly ignored (never whitelist) ────────────────────────────────────────
# .data/          — ephemeral session data, scratchpads, manifests
# result/         — nix build output symlink
